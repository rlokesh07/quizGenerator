# --- Firebase Client (Google Auth) ---
# From your Firebase project settings > General > Your apps > Web app config.
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# --- Firebase Admin (Firestore) ---
# From your Firebase service account JSON. Keep these secret.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Paste the private key with literal \n for newlines, wrapped in quotes.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"

# --- OpenAI (embeddings for question search) ---
OPENAI_API_KEY=sk-...
# Optional overrides
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Unkey (API key auth, self-hosted via docker-compose) ---
# URL of the local Unkey API server (default: http://localhost:8080)
UNKEY_SERVER_URL=http://localhost:8080
# Root key from the Unkey dashboard / API (used server-side only)
UNKEY_ROOT_KEY=unkey_...
# The API ID created in your Unkey workspace whose keys are considered valid
UNKEY_API_ID=api_...
